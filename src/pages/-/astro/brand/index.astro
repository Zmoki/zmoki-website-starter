---
import BrandLayout from "@/layouts/BrandLayout.astro";
import { colors } from "@/design-tokens.mjs";

const neutral = colors["zmoki-neutral"] as Record<string, string>;

// A light→dark monochrome ramp for the hero strip — white through the neutral
// scale to near-black — so it reads as an intentional greyscale.
const palettePreview = ["#ffffff", neutral["200"], neutral["400"], neutral["600"], neutral["900"]];

// Sections of the design system. `href` null = not built yet.
const sections = [
  {
    title: "Color",
    summary: "A flat, monochrome token system — black, white, and grey.",
    href: "/-/astro/brand/color/",
    accent: "bg-zmoki-neutral-900",
  },
  {
    title: "Typography",
    summary: "Noto Serif headings, Noto Sans body, Noto Sans Mono labels.",
    href: "/-/astro/brand/typography/",
    accent: "bg-zmoki-neutral-900",
  },
  {
    title: "Forms",
    summary: "Inputs, labels, the action button, focus and error states.",
    href: "/-/astro/brand/forms/",
    accent: "bg-zmoki-neutral-900",
  },
  {
    title: "Components",
    summary: "Nav, footer, hero, cards, links, and buttons as reusable blocks.",
    href: "/-/astro/brand/components/",
    accent: "bg-zmoki-neutral-900",
  },
  {
    title: "Voice & tone",
    summary: "How My Project X sounds. Clear, honest, helpful, human.",
    href: "/-/astro/brand/voice/",
    accent: "bg-zmoki-neutral-900",
  },
];
---

<BrandLayout
  title="Brand — My Project X design system"
  description="The brand and design system guideline for My Project X"
>
  <header
    class="mb-8 overflow-hidden rounded-xl border-2 border-zmoki-neutral-900 bg-zmoki-neutral-900 text-slate-50"
  >
    <div class="px-6 py-10 md:px-10 md:py-14">
      <p class="font-mono text-xs uppercase tracking-normal opacity-70">My Project X</p>
      <h1 class="mt-2 text-4xl font-semibold md:text-6xl">Design system</h1>
      <p class="mt-4 max-w-2xl text-xl md:text-2xl">
        The living guideline for how My Project X looks and feels — a flat, monochrome, brutalist
        system. One source of truth for color, type, and components.
      </p>
    </div>
    <div class="flex h-3">
      {palettePreview.map((hex) => <span class="flex-1" style={`background-color: ${hex}`} />)}
    </div>
  </header>

  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
    {
      sections.map((section) =>
        section.href ? (
          <a
            href={section.href}
            class="group flex flex-col gap-3 rounded-xl border-2 border-zmoki-neutral-900 bg-white p-6 transition-transform hover:-translate-y-1 md:p-8"
          >
            <span class={`h-2 w-12 rounded-full ${section.accent}`} />
            <h2 class="text-2xl font-semibold md:text-3xl">
              <span class="border-b-4 border-dotted border-current">{section.title}</span>
            </h2>
            <p class="opacity-80">{section.summary}</p>
            <span class="mt-2 font-mono text-xs uppercase tracking-normal opacity-60">View →</span>
          </a>
        ) : (
          <div class="flex flex-col gap-3 rounded-xl border-2 border-dashed border-slate-300 bg-white/50 p-6 md:p-8">
            <span class={`h-2 w-12 rounded-full opacity-30 ${section.accent}`} />
            <h2 class="text-2xl font-semibold opacity-50 md:text-3xl">{section.title}</h2>
            <p class="opacity-50">{section.summary}</p>
            <span class="mt-2 font-mono text-xs uppercase tracking-normal opacity-40">
              Coming soon
            </span>
          </div>
        ),
      )
    }
  </div>
</BrandLayout>
