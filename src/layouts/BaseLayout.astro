---
import PostHog from "@/components/posthog.astro";
import { site } from "@/site.config";

export interface Props {
  title: string;
  description?: string;
  publishDate?: Date;
  contentModifiedDate?: Date;
  /**
   * When true, <main> spans the full viewport width so the page can render
   * full-bleed landing sections that manage their own inner containers.
   * Default false = a centered, readable container for articles and pages.
   */
  wide?: boolean;
}

const {
  title,
  description = site.description,
  publishDate,
  contentModifiedDate,
  wide = false,
} = Astro.props;

const isProduction = import.meta.env.PROD;
const analyticsEnabled = import.meta.env.PUBLIC_ANALYTICS_ENABLED !== "false";

const siteBaseUrl = Astro.site;
const currentBaseUrl = isProduction ? siteBaseUrl : `http://localhost:${Astro.url.port}`;

const pagePathname = Astro.url.pathname;
const isPageArticle = publishDate && contentModifiedDate;

const canonicalURL = new URL(pagePathname, siteBaseUrl).toString();

const pageImageWideUrl = new URL(
  `/og-images${isPageArticle ? pagePathname : "/"}wide.jpg`,
  currentBaseUrl,
).toString();

const currentYear = new Date().getFullYear();
const copyrightYears =
  currentYear > site.copyrightStartYear
    ? `${site.copyrightStartYear}–${currentYear}`
    : `${site.copyrightStartYear}`;
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans:ital,wght@0,100..900;1,100..900&family=Noto+Sans+Mono:wght@100..900&family=Noto+Serif:ital,wght@0,100..900;1,100..900&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="max-image-preview:large" />
    <link rel="canonical" href={canonicalURL} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="RSS Feed"
      href={new URL("rss.xml", siteBaseUrl).toString()}
    />

    <!-- Open Graph meta tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content={isPageArticle ? "article" : "website"} />
    <meta property="og:site_name" content={site.ogSiteName} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={pageImageWideUrl} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="675" />
    {
      isPageArticle && (
        <meta property="article:published_time" content={publishDate.toISOString()} />
      )
    }
    {
      isPageArticle && (
        <meta property="article:modified_time" content={contentModifiedDate.toISOString()} />
      )
    }
    <meta property="twitter:card" content="summary_large_image" />

    {analyticsEnabled && <PostHog />}
  </head>
  <body
    class="flex min-h-full flex-col bg-zmoki-neutral-200 font-sans text-lg leading-tight tracking-tight text-zmoki-neutral-900 xl:text-xl"
  >
    <!-- Top navigation -->
    <header class="sticky top-0 z-40 border-b-2 border-zmoki-neutral-900 bg-white">
      <nav
        class="mx-auto flex w-full max-w-6xl items-center justify-between gap-4 px-4 py-4 lg:px-8"
      >
        <a href="/" class="font-serif text-xl font-bold uppercase tracking-tight">{site.name}</a>
        <div class="flex items-center gap-4 md:gap-6">
          <ul class="hidden items-center gap-6 md:flex">
            {
              site.nav.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="font-mono text-sm uppercase tracking-tight text-zmoki-neutral-900"
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
          <a
            href={site.cta.href}
            class="border-2 border-zmoki-neutral-900 bg-zmoki-neutral-900 px-4 py-2 font-mono text-sm font-bold uppercase tracking-tight text-slate-50"
            >{site.cta.label}</a
          >
        </div>
      </nav>
    </header>

    <!-- Main content -->
    <main class:list={["w-full flex-1", !wide && "mx-auto max-w-3xl px-4 py-10 lg:py-16"]}>
      <slot />
    </main>

    <script is:inline>
      document.querySelector('a[href^="mailto:"]')?.addEventListener("click", function () {
        window.posthog?.capture("contact_email_clicked", {
          email: this.getAttribute("href").replace("mailto:", ""),
        });
      });
    </script>

    <!-- Footer -->
    <footer class="border-t-2 border-zmoki-neutral-900 bg-white">
      <div
        class="mx-auto flex w-full max-w-6xl flex-col gap-4 px-4 py-8 font-mono text-xs uppercase tracking-tight text-zmoki-neutral-600 md:flex-row md:items-center md:justify-between lg:px-8"
      >
        <p>&copy; {site.name} {copyrightYears}</p>
        <nav class="flex flex-wrap items-center gap-x-6 gap-y-2">
          <a href="/legal/privacy/">Privacy</a>
          <a href="/legal/terms/">Terms</a>
          <a href={`mailto:${site.contact.email}`}>Contact</a>
          <a href={site.social.sourceRepo} target="_blank" rel="noopener noreferrer">Source</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
